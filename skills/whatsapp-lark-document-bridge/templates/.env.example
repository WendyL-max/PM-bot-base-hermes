# WhatsApp-Lark Bridge 環境變量配置

# Lark API 配置
LARK_APP_ID=cli_aaa03a9afd399eea
LARK_APP_SECRET=your_app_secret_here
LARK_DOCUMENT_BASE_URL=https://open.feishu.cn/open-apis
LARK_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token

# WhatsApp Business API 配置
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_token

# 應用配置
APP_PORT=5000
APP_ENV=development
DEBUG=true

# 資料庫配置 (可選)
DATABASE_URL=sqlite:///app.db

# 日誌配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 快取配置
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300